# OddsPapi (Pflicht für Live-Quoten) — https://oddspapi.io
ODDSPAPI_API_KEY=your-oddspapi-key
ODDSPAPI_TOURNAMENT_ID=16
ODDSPAPI_BOOKMAKER=pinnacle

# The Odds API (optionaler Quoten-Fallback) — https://the-odds-api.com
THE_ODDS_API_KEY=

# Spielplan: lokal aus data/schedule/worldcup.json (openfootball, kein Key nötig)
# Aktualisieren: python scripts/fetch_schedule.py
# SCHEDULE_PATH=data/schedule/worldcup.json

# API-Football (optional, nicht für Spielplan nötig) — https://www.api-football.com
# API_FOOTBALL_API_KEY=

# Kicktipp-Abgabe (GitHub Actions / scripts/submit_kicktipp.py)
# KICKTIPP_EMAIL=
# KICKTIPP_PASSWORD=
# KICKTIPP_COMMUNITY=entertainment

# Optional
TIMEZONE=Europe/Berlin
THE_ODDS_API_SPORT=soccer_fifa_world_cup
